{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aperio-J",
  "version": "0.3.0",
  "identifier": "dev.aperio-j.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3010",
    "beforeDevCommand": "pnpm --filter @aperio-j/web dev",
    "beforeBuildCommand": "pnpm --filter @aperio-j/desktop prepare:server"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aperio-J",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "url": "http://127.0.0.1:3010"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "server/**/*"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
