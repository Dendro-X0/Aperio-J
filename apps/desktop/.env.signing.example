# Copy to .env.signing and customize. Never commit real secrets.

# --- Windows (optional self-signed PFX) ---
# APERIO_J_WIN_CERT_PFX=apps/desktop/.signing/aperio-j-windows.pfx
# APERIO_J_WIN_CERT_PASSWORD=aperio-j-local
# APERIO_J_WIN_TIMESTAMP_URL=http://timestamp.digicert.com

# --- Android (OSS upload keystore; committed for CI sideload builds) ---
# APERIO_J_ANDROID_KEYSTORE=apps/desktop/signing/android-upload.jks
# APERIO_J_ANDROID_KEY_ALIAS=aperio-j-upload
# APERIO_J_ANDROID_KEY_PASSWORD=aperio-j-local

# --- Android release (self-hosted web URL baked into APK) ---
# APERIO_J_WEB_URL=https://aperio.example.com
# APERIO_J_WEB_URL=http://192.168.1.42:3010
# APERIO_J_ANDROID_ALLOW_LOCALHOST=1
# APPLE_DEVELOPMENT_TEAM=XXXXXXXXXX
# APPLE_SIGNING_IDENTITY=Apple Development
