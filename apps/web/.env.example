DATABASE_URL="file:../../data/aperio-j.db"

# Required in production for POST/GET /api/cron/refresh
# CRON_SECRET="change-me"

# Optional cron intervals (defaults: 6h match, 7d re-discovery)
# APERO_J_CRON_MATCH_INTERVAL_HOURS=6
# APERO_J_DETAIL_FETCH=false
# APERO_J_DETAIL_FETCH_LIMIT=8

# Search probe (Layer 1 bounded web discovery)
# APERO_J_SEARCH_PROBE=false
# APERO_J_SEARCH_PROBE_QUERIES=2

# API connectors (Phase 6 — see docs/connector-roadmap.md)
# APERO_J_CONNECTORS_ENABLED=remotive,remoteok,arbeitnow,adzuna,bundesagentur
# APERO_J_CONNECTOR_FIXTURES=true
# APERO_J_CONNECTOR_MAX_ITEMS=50
# APERO_J_ADZUNA_APP_ID=
# APERO_J_ADZUNA_APP_KEY=
# APERO_J_DISCOVERY_FALLBACK=false

# Mainland China: headless browser fetch for BOSS/51job/Lagou (requires: pnpm exec playwright install chromium)
# APERO_J_CN_PLAYWRIGHT=true
