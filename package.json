{
  "name": "aperio-j",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "build:web": "pnpm --filter @aperio-j/web build",
    "typecheck": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @aperio-j/web typecheck",
    "test": "pnpm --filter \"./packages/*\" build && pnpm -r --filter \"./packages/*\" test",
    "fixture:run": "pnpm build && node scripts/fixture-run.mjs",
    "source:discover": "pnpm build && node scripts/source-discovery-run.mjs",
    "cron:refresh": "dotenv -c -- pnpm --filter @aperio-j/web cron:refresh",
    "dev": "pnpm --filter @aperio-j/web dev",
    "dev:desktop": "pnpm --filter @aperio-j/desktop dev",
    "build:desktop": "pnpm --filter @aperio-j/desktop build",
    "dev:android": "pnpm --filter @aperio-j/desktop dev:android",
    "dev:ios": "pnpm --filter @aperio-j/desktop dev:ios",
    "dev:mobile": "pnpm --filter @aperio-j/desktop dev:android",
    "build:android": "pnpm --filter @aperio-j/desktop build:android",
    "build:ios": "pnpm --filter @aperio-j/desktop build:ios",
    "build:mobile": "pnpm --filter @aperio-j/desktop build:android",
    "db:push": "dotenv -c -- pnpm --filter @aperio-j/db push",
    "db:generate": "dotenv -c -- pnpm --filter @aperio-j/db generate",
    "postinstall": "node scripts/rebuild-native-modules.mjs",
    "native:rebuild": "node scripts/rebuild-native-modules.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@aperio-j/discovery": "workspace:*",
    "@aperio-j/matcher": "workspace:*",
    "@aperio-j/probe": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "dotenv-cli": "^11.0.0",
    "typescript": "^6.0.3"
  }
}
